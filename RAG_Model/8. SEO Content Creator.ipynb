    "\n",
    "    Note: Only provide the list of questions, nothing else.\n",
    "    \"\"\"\n",
    "    )\n",
    "\n",
    "Question_Chain = Question_Prompt | Question_llm  #model1_temp\n",
    "\n",
    "\n",
    "url = \"https://www.boneinlayfurnitures.com/products/hand-carved-menagerie-buffet-black-credenza\"\n",
    "Question_Output = Question_Chain.invoke({\"URL\": url})\n",
    "print(Question_Output.Question)\n",
    "AI_Question_list = Question_Output.Question\n"
   ]
