    "# Product Specific AI Question\n",
    "\n",
    "class Question_Details(BaseModel):\n",
    "    Question : List[str]  = Field(description='A list of 5-6 conversational questions frequently asked by users about the product.')\n",
    "    \n",
    "\n",
    "Question_llm = model1.with_structured_output(Question_Details)\n",
    "# parser = PydanticOutputParser(pydantic_object=Feedback)\n",
    "\n",
    "Question_Prompt = ChatPromptTemplate.from_template(\n",
    "    \"\"\"\n",
    "    You are a professional SEO expert. Your task is to generate a list of 5-6 natural language, conversational questions that a user would likely ask when researching or considering the product at the following URL: {URL}.\n",
