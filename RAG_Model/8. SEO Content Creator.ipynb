    "    Longtail_Chain = Longtail_Prompt | Longtail_llm\n",
    "    \n",
    "    Long_tail_Keywords_list = []\n",
    "    for loc in location:\n",
    "        Longtail_Output = Longtail_Chain.invoke({\"Product_name\": Product_name, \"location\":loc})\n",
    "        #print(loc,\"------\",Longtail_Output.Long_Tail_Keywords)\n",
