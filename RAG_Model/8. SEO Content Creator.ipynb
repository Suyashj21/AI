    "# Long Tail Keywords from competitor\n",
    "\n",
    "class Longtail_Details(BaseModel):\n",
    "    Long_Tail_Keywords: List[str] = Field(description='A list of 5 to 6 most conversion-centric long-tail keywords from top websites in the {location}.')\n",
    "\n",
    "Longtail_llm = model1.with_structured_output(Longtail_Details)\n",
    "\n",
    "Longtail_Prompt = ChatPromptTemplate.from_template(\n",
    "    \"\"\"\n",
    "    You are a professional SEO expert with access to real-time search data.\n",
