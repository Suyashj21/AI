    "\n",
    "from typing import TypedDict, Literal, Annotated, List\n",
    "from pydantic import BaseModel, Field\n",
    "from langchain_core.output_parsers import StrOutputParser\n",
    "from langchain_core.prompts import ChatPromptTemplate \n",
    "\n",
    "class Living_Spaces(BaseModel):\n",
    "    # Prod_name : str\n",
    "    Prod_type: Literal['Bed','Bed Headboard','Bedside','Nightstand' ,'Sideboard', 'Cabinet','Credenza','Almirah', 'Armoire', 'Buffet', 'Coffee Table', 'Center Table', 'Dining Table', 'Dining Chair', 'Living Room Chairs', 'Sofa Chair', 'Mirror Frame', 'Daybed','CHEST OF DRAWER', 'DRESSER','Bookcase','hutch','Work Desk','Office Desk','Media Consoles','TV Stand','Media Unit']  = Field(description='Choose the Product type which would be most relevant to the Product exist in given URL') \n",
    "    # Art_Work : Literal['Bone Inlay Furniture', 'Hand Carved Furniture', 'Metal Embossed Furniture', 'Reclaimed Wood Furniture'] = Field(description='Choose the Furniture art work from given list which would be most relevant to the Product exist in given URL')\n",
    "    Living_Area: Literal['Bed Room', 'Dining Room', 'Living Room', 'Study Room','Outdoor'] = Field(description='Choose the Living Space name from given list which would be the most relevant to the Product exist in given URL')\n",
    "    # Prod_Description : List[str] = Field(description='Pull Product description of the Product exist in given URL without including dimension and key points')\n",
    "    # Page_Keywords : str = Field(description='Pull the list of existing keywords from the Product page exist in given URL')\n",
    "\n",
    "Living_Spaces_llm = model1.with_structured_output(Living_Spaces)\n",
    "\n",
    "Living_Spaces_Prompt = ChatPromptTemplate.from_template(\n",
    "    \"\"\"\n",
    "    You are an expert AI assistant who need to identify which living space and Product type is suitable for furniture, detaile shared below. \\n\n",
    "\n",
    "    Product_name : {Product_name}\n",
    "    Product_Discription : {Product_Discription}\n",
    "    \"\"\"\n",
    "    )\n",
    "\n",
    "\n",
    "\n",
    "Living_Spaces_Chain = Living_Spaces_Prompt | Living_Spaces_llm\n",
    "Living_Spaces_Output = Living_Spaces_Chain.invoke({'Product_name': Product_name, 'Product_Discription':Product_Discription})\n",
    "\n",
    "print(Living_Spaces_Output.Living_Area, Living_Spaces_Output.Prod_type)\n",
    "\n",
    "\n",
    "\n"
   ]
