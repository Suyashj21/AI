    "graph.add_edge('Basic_Details','New_Description')\n",
    "graph.add_edge('New_Description','New_Meta_Description')\n",
    "graph.add_edge('New_Description','New_Meta_Heading')\n",
    "\n",
    "#>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>------------------\n",
