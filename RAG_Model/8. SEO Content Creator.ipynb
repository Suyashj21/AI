    "import os\n",
    "from dotenv import load_dotenv\n",
    "from langchain_google_genai import ChatGoogleGenerativeAI\n",
    "\n",
    "# Load the environment variables from the .env file\n",
    "load_dotenv()\n",
    "\n",
    "# Retrieve the API keys from the environment\n",
    "api_key_1 = os.getenv(\"GEMINI_API_KEY_1\")\n",
    "api_key_2 = os.getenv(\"GEMINI_API_KEY_2\")\n",
    "\n",
    "model1_temp = ChatGoogleGenerativeAI(model='gemini-2.5-flash-lite', google_api_key = api_key_1,temperature=0.7)   # More Creative\n",
    "model2_temp = ChatGoogleGenerativeAI(model='gemini-2.5-flash-lite', google_api_key = api_key_2,temperature=0.7)   # More Creative\n",
    "model1_lite = ChatGoogleGenerativeAI(model='gemini-2.5-flash-lite', google_api_key = api_key_1)  # Less Powerfull\n",
    "model2_lite = ChatGoogleGenerativeAI(model='gemini-2.5-flash-lite', google_api_key = api_key_2)  # Less Powerfull\n",
    "model1 = ChatGoogleGenerativeAI(model='gemini-2.5-flash', google_api_key = api_key_1)\n",
    "model2 = ChatGoogleGenerativeAI(model='gemini-2.5-flash', google_api_key = api_key_2)\n",
    "\n",
    "location = ['United State of America','United Kingdom','Switzerland']\n",
    "market = ['US','UK','Swiss']\n",
    "Website_URL = \"https://www.boneinlayfurnitures.com\""
   ]
