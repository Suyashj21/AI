    "        Longtail_Keywords = [item for sublist in Long_tail_Keywords_list for item in sublist]\n",
    "    print(\"Longtail_keyword_Search : \",Longtail_Keywords)\n",
    "    return {'Longtail_Keywords':Longtail_Keywords}\n"
   ]
