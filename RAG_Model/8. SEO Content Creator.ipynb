    "# Product Specific AI Question\n",
    "\n",
    "\n",
    "Answer_Prompt = ChatPromptTemplate.from_template(\n",
    "    \"\"\"\n",
    "    You are a professional AI assistant. Your task is to provide a very short, one to three-word answer to the question based on the content of the product page URL.\n",
    "\n",
    "    Question: {question}\n",
    "    Product Page URL: {URL}\n",
    "\n",
    "    Provide only the answer. If the answer is not on the page, respond with a single dash (-).\n",
    "    \"\"\"\n",
    "    )\n",
    "\n",
    "Answer_Chain = Answer_Prompt | model1  #model1_temp\n",
    "\n",
    "def que_ans_pair(key,value):\n",
    "    \"\"\"Question and Prompt pair\"\"\"\n",
    "    new_dict = {}\n",
    "    new_dict[key] = value\n",
    "    return new_dict\n",
    "\n",
    "que_ans_pair_list = []\n",
    "\n",
    "url = \"https://www.boneinlayfurnitures.com/products/hand-carved-menagerie-buffet-black-credenza\"\n",
    "for question in AI_Question_list:\n",
    "    Answer_Output = Answer_Chain.invoke({\"URL\": url,\"question\":question})\n",
    "    que_ans = que_ans_pair(question,Answer_Output.content)\n",
    "    que_ans_pair_list.append(que_ans)\n",
    "    print(question)\n",
    "    print(Answer_Output.content)\n",
    "    print(\"----------------------------------------------\")\n",
    "\n"
   ]
